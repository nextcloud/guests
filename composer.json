{
	"name": "nextcloud/guests",
	"config": {
		"platform": {
			"php": "8.1"
		},
		"sort-packages": true,
		"allow-plugins": {
			"bamarni/composer-bin-plugin": true
		},
		"optimize-autoloader": true,
		"autoloader-suffix": "Guests"
	},
	"autoload": {
		"psr-4": {
			"OCA\\Guests\\": "lib/"
		}
	},
	"scripts": {
		"post-install-cmd": [
			"@composer bin all install --ansi"
		],
		"post-update-cmd": [
			"@composer bin all install --ansi"
		],
		"lint": "find . -name \\*.php -not -path './vendor/*' -print0 | xargs -0 -n1 php -l",
		"cs:check": "php-cs-fixer fix --dry-run --diff",
		"cs:fix": "php-cs-fixer fix",
		"psalm": "psalm --no-cache --threads=$(nproc)",
		"psalm:update-baseline": "psalm --threads=1 --update-baseline",
		"psalm:update-baseline:force": "psalm --threads=1 --update-baseline --set-baseline=tests/psalm-baseline.xml",
		"test:unit": "phpunit -c phpunit.xml --colors=always --fail-on-warning --fail-on-risky --display-deprecations --display-phpunit-deprecations",
		"rector": "rector && composer cs:fix"
	},
	"require": {
		"bamarni/composer-bin-plugin": "^1.9"
	}
}
